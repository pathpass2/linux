name: Build rk3566-tspi.img

on:
  push:
    branches: [ main ]
  workflow_dispatch:

env:
  ARCH: arm64


jobs:
  build:
    runs-on: ubuntu-22.04
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          submodules: recursive
          # 关键：保留文件权限
          persist-credentials: false




          


      - name: Build Kernel
        run: |   
          echo "$(pwd)"
          ls


          
